# EduGuard backend environment template
# FORENSIC ANNOTATION: Keep all secrets outside source control; copy this file to .env and replace every placeholder.

# Flask runtime
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# JWT signing keys
# FORENSIC ANNOTATION: Use PEM env vars on Vercel; keep path-based fallbacks for local development.
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_PRIVATE_KEY_PATH=keys/server_private.pem
JWT_PUBLIC_KEY_PATH=keys/server_public.pem

# Database path
# FORENSIC ANNOTATION: SQLite database file for offline-first operation and forensic auditing.
DATABASE_PATH=data/eduguard.db

# Token lifetimes
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# TLS certificate paths
# FORENSIC ANNOTATION: Local HTTPS certificate used for LAN deployment without internet PKI.
TLS_CERT_PATH=certs/server.crt
TLS_KEY_PATH=certs/server.key

# Server binding
HOST=0.0.0.0
PORT=5000

# Optional debug mode
DEBUG=false
